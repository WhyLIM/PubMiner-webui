# Root environment template for local PubMiner development
#
# Preferred workflow:
# 1. Copy this file to `.env.local`
# 2. Fill in the real values on your machine
# 3. Do not commit `.env.local`

# Required by NCBI
NCBI_EMAIL=your-email@example.com

# Optional, improves NCBI rate limits
NCBI_API_KEY=

# Required for GLM extraction
ZHIPU_API_KEY=

# Optional, used for DOI-based OA PDF fallback
UNPAYWALL_EMAIL=your-email@example.com

# Frontend -> backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional NextAuth values if auth is enabled later
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3001

# Optional Prisma local database
DATABASE_URL="file:./db/dev.db"
